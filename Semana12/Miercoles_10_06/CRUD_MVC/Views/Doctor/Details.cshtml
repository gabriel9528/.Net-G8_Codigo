@model CRUD_MVC.Models.OneToMany.Doctor

@{
    ViewData["Title"] = "Detalle del Doctor";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">Detalle del Doctor</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">ID:</dt>
                        <dd class="col-sm-9">@Model.Id</dd>

                        <dt class="col-sm-3">Nombre:</dt>
                        <dd class="col-sm-9">@Model.Name</dd>

                        <dt class="col-sm-3">Telefono:</dt>
                        <dd class="col-sm-9">@Model.Phone</dd>

                        <dt class="col-sm-3">Email:</dt>
                        <dd class="col-sm-9">@Model.Email</dd>

                        <dt class="col-sm-3">Pacientes Asignados:</dt>
                        <dd class="col-sm-9">
                            @if (Model.ListPatients != null && Model.ListPatients.Any(p => !p.IsDeleted))
                            {
                                <div class="table-responsive mt-2">
                                    <table class="table table-sm table-bordered">
                                        <thead class="table-light">
                                            <tr>
                                                <th>ID</th>
                                                <th>Nombre del Paciente</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var patient in Model.ListPatients.Where(p => !p.IsDeleted))
                                            {
                                                <tr>
                                                    <td>@patient.Id</td>
                                                    <td>@patient.Name</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">No tiene pacientes asignados</span>
                            }
                        </dd>
                    </dl>

                    <div class="d-flex justify-content-between mt-3">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                            Editar
                        </a>
                        <a asp-action="Index" class="btn btn-secondary">
                            Volver a la lista
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>