@model CRUD_MVC.Models.OneToMany.Doctor

@{
    ViewData["Title"] = "Eliminar Doctor";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Eliminar Doctor</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h5>¿Estás seguro de eliminar este doctor?</h5>
                        <p>Esta acción no se puede deshacer.</p>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-3">ID:</dt>
                        <dd class="col-sm-9">@Model.Id</dd>

                        <dt class="col-sm-3">Nombre:</dt>
                        <dd class="col-sm-9">@Model.Name</dd>

                        <dt class="col-sm-3">Teléfono:</dt>
                        <dd class="col-sm-9">@Model.Phone</dd>

                        <dt class="col-sm-3">Email:</dt>
                        <dd class="col-sm-9">@Model.Email</dd>
                    </dl>

                    @if (Model.ListPatients != null && Model.ListPatients.Any(p => !p.IsDeleted))
                    {
                        <div class="alert alert-danger">
                            <strong>Atención:</strong> Este doctor tiene @Model.ListPatients.Count(p => !p.IsDeleted) paciente(s) asignado(s).
                            Si lo eliminas, estos pacientes quedarán sin doctor asignado.
                        </div>
                    }

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>