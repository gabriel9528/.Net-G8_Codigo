<Window x:Class="WPF_StackPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_StackPanel"
        mc:Ignorable="d"
        Title="Stack Panel" Height="450" Width="800">
    <StackPanel x:Name="Panel">
        <Button x:Name="Button1" Content="Button 1" Width="100" Height="50" Margin="15" HorizontalAlignment="Left" />
        <Button x:Name="Button2" Content="Button 2" Width="100" Height="50" Margin="15" HorizontalAlignment="Center" />
        <Button x:Name="Button3" Content="Button 3" Width="100" Height="50" Margin="15" HorizontalAlignment="Right" />
    </StackPanel>
</Window>
