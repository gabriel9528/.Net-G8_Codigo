<Window x:Class="Segundo_ejercicio_WPF.VentanaJugar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Segundo_ejercicio_WPF"
        mc:Ignorable="d"
        Title="VentanaJugar" Height="450" Width="800">
    <Grid>
        <Label Name="labelPregunta" Content="Pregunta" HorizontalAlignment="Center"
               Margin="0,109,0,35" VerticalContentAlignment="Top" Width="200" FontSize="18" />
        <TextBox Name="textBoxRespuesta" HorizontalAlignment="Center"
                 TextWrapping="Wrap" VerticalAlignment="Center" Width="200" Height="35" 
                 FontSize="18" Background="#fff3bbbb"/>
        <Button Name="buttonConsultar" HorizontalAlignment="Center" Margin="0,251,0,0"
                VerticalAlignment="Top" Height="30" Width="200" Content="Consultar" Click="buttonConsultar_Click"/>
        <Button Name="buttonVolver" HorizontalAlignment="Left" Margin="80, 330, 0, 0"
        VerticalAlignment="Top" Height="45" Width="90" Content="Volver" Click="buttonVolver_Click"/>
    </Grid>
</Window>
