<Window x:Class="Segundo_ejercicio_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Segundo_ejercicio_WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button x:Name="buttonConfigurar" Content="Configurar" HorizontalAlignment="Left" 
                Margin="85, 240, 0, 0" VerticalAlignment="Top" Height="140" Width="180" Click="buttonConfigurar_Click" />

        <Button x:Name="buttonEmpezarJuego" Content="Empezar a jugar" HorizontalAlignment="Left" 
        Margin="500, 240, 0, 0" VerticalAlignment="Top" Height="140" Width="180" Click="buttonEmpezarJuego_Click" />
    </Grid>
</Window>
