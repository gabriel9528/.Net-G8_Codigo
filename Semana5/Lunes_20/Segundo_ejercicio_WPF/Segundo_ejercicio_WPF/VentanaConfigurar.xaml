<Window x:Class="Segundo_ejercicio_WPF.VentanaConfigurar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Segundo_ejercicio_WPF"
        mc:Ignorable="d"
        Title="VentanaConfigurar" Height="450" Width="800">
    <Grid>
        <Label Name="labelPais" Content="Pais" HorizontalAlignment="Left" 
           Margin="116,80,0,0" VerticalAlignment="Top" Background="#fff5c4c4" />
        <TextBox x:Name="textBoxPais" HorizontalAlignment="Left" Margin="155, 80, 0, 0" 
             TextWrapping="Wrap" VerticalAlignment="Top" Width="270" 
             Background="#ffb4c8ef" Height="25" />
        <Label Name="labelCapital" Content="Capital" HorizontalAlignment="Left" 
   Margin="100,124,0,0" VerticalAlignment="Top" Background="#fff5c4c4" />
        <TextBox x:Name="textBoxCapital" HorizontalAlignment="Left" Margin="155,124,0,0" 
     TextWrapping="Wrap" VerticalAlignment="Top" Width="270" 
     Background="#ffb4c8ef" Height="25" />
        <Button x:Name="buttonIngresar" Content="Ingresar" HorizontalAlignment="Left"
            Margin="155, 180, 0, 0" VerticalAlignment="Top" Width="270" Height="25" Click="buttonIngresar_Click" />

        <Button x:Name="buttonVolver" Content="Volver" HorizontalAlignment="Left"
    Margin="80, 320, 180, 0" VerticalAlignment="Top" Width="60" Height="45" Click="buttonVolver_Click" />

        <Button x:Name="buttonJugar" Content="Empezar a jugar" HorizontalAlignment="Left"
    Margin="607,315,0,0" VerticalAlignment="Top" Width="100" Height="45" Click="buttonJugar_Click" />

        <ListBox x:Name="listBoxRegiones" Margin="500,80,24,242" />
    </Grid>
</Window>
